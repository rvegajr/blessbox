{
  "mcpServers": {
    "blessbox-bugfix": {
      "command": "node",
      "args": ["mcp-server/src/index.js"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}",
        "GITHUB_REPO": "rvegajr/BlessBox"
      }
    },
    "jam": {
      "type": "http",
      "url": "https://mcp.jam.dev/mcp",
      "headers": {
        "Authorization": "Bearer ${JAM_PAT}"
      }
    }
  }
}
