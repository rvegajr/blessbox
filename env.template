# BlessBox Environment Variables Template
# ========================================
# Instructions:
# 1. Copy this file to .env.local for development
# 2. Fill in your actual values
# 3. Never commit files with real credentials

# Database (Turso) - REQUIRED
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here
# SAFETY: In test envs (.env.test.local) point TURSO_DATABASE_URL at a THROWAWAY
# DB (e.g. file:./test.db) and SQUARE_ENVIRONMENT=sandbox — NEVER the production
# database or live Square. tests/setup.ts refuses to run if the URL contains "prod".

# Email Service - REQUIRED (Choose Gmail OR SendGrid OR SMTP/MailHog)
# Email — handled entirely by the Noctusoft gateway relay (it holds the real
# SendGrid key). The app authenticates with NOCTUSOFT_DEPLOY_KEY only and holds
# NO SendGrid / SMTP / Gmail credentials.
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=BlessBox
# SENDGRID_API_URL=https://api.sendgrid.noctusoft.com   # optional; this is the default relay host
EMAIL_REPLY_TO=

# Security - REQUIRED
JWT_SECRET=generate-32-char-minimum-secret-here

# Application - DEFAULT PORT 7777
# Server/base URL used for emails and server-side link generation
PUBLIC_APP_URL=http://localhost:7777
# Client-exposed base URL (keep in sync with PUBLIC_APP_URL)
NEXT_PUBLIC_APP_URL=http://localhost:7777

# Payment + Email gateway (Noctusoft) - REQUIRED
# The Noctusoft gateway is a Square/SendGrid drop-in proxy that holds the real
# upstream credentials + credits. The app authenticates with this ONE key — it
# holds NO direct SQUARE_ACCESS_TOKEN or SENDGRID_API_KEY.
NOCTUSOFT_DEPLOY_KEY=your-noctusoft-deploy-key
NOCTUSOFT_WEBHOOK_SECRET=your-noctusoft-webhook-secret

# Square (public, non-secret) — used by the frontend Web Payments SDK only.
SQUARE_APPLICATION_ID=your-square-application-id
SQUARE_LOCATION_ID=your-square-location-id
SQUARE_ENVIRONMENT=sandbox

# NextAuth - REQUIRED (using port 7777)
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:7777

# Super Admin - REQUIRED
SUPERADMIN_EMAIL=admin@blessbox.app
# Super-admin password (bcrypt hash, cost 12)
# Generate hash via: npx tsx scripts/hash-password.ts <your-password>
# SUPERADMIN_PASSWORD_HASH=$2a$12$...your-hash-here

# Diagnostics (Optional but recommended in production)
# Used to protect /api/system/email-health and other diagnostics endpoints.
# DIAGNOSTICS_SECRET=generate-a-long-random-secret

# Production QA Testing (Optional - only needed for production QA coverage)
# These secrets enable passwordless test login and deterministic data seeding in production
# Set in Vercel/CI environment variables (not in git)
# PROD_TEST_LOGIN_SECRET=your-production-test-login-secret
# PROD_TEST_SEED_SECRET=your-production-test-seed-secret

# Development Settings
NODE_ENV=development
ENABLE_DEBUG_LOGGING=true

# Traklet Dev Widget (DEVELOPMENT ONLY)
# ------------------------------------------------------------------
# The Traklet floating issue-tracker is a developer tool. It is hard-gated
# off in production by `NODE_ENV !== 'production'` in `app/layout.tsx` and
# in `app/api/dev/traklet-proxy/route.ts`. NEVER set these in production.
#
# TRAKLET_PAT is server-only (no NEXT_PUBLIC_ prefix). It is read by the
# proxy route at /api/dev/traklet-proxy and forwarded to api.github.com so
# the GitHub PAT is never shipped to the browser.
# TRAKLET_PAT=ghp_your_personal_access_token_here
# NEXT_PUBLIC_TRAKLET_ENABLED=true

# Traklet Test Case Sync (DEVELOPMENT ONLY)
# ------------------------------------------------------------------
# Used by `npx traklet sync` to create/update GitHub Issues for test cases.
# Requires GitHub PAT with repo:write scope on rvegajr/blessbox.
# Same value as TRAKLET_PAT above (used by CLI, not the dev widget proxy).
# NEVER set in production.
# TRAKLET_PAT=ghp_your_personal_access_token_here